<!-- CALENDARIO -->
<section
  class="relative py-6 px-6 sm:px-8 md:px-12 overflow-visible"
  id="seccion-calendario"
>
  <div class="max-w-sm sm:max-w-sm md:max-w-md mx-auto px-4">
    <!-- CARD -->
    <div
      class="bg-white rounded-3xl shadow-lg border-2 border-[#c9968d] p-4 md:p-8 relative z-10"
      id="calendario-card"
    >
      <!-- TÍTULO DEL MES -->
      <div
        class="flex items-center justify-center gap-4 md:gap-6 mb-6"
        id="titulo-mes-container"
      >
        <div class="w-12 h-px bg-[#c9968d]" id="linea-izq"></div>
        <h3
          class="font-cathylise text-[#63778d]"
          style="font-size: clamp(2rem, 8vw, 3rem);"
          id="nombre-mes"
        >
        </h3>
        <div class="w-12 h-px bg-[#c9968d]" id="linea-der"></div>
      </div>

      <!-- DÍAS DE LA SEMANA -->
      <div class="grid grid-cols-7 gap-1 md:gap-2 mb-3">
        <div
          class="text-center font-callingstone text-sm md:text-base text-[#c9968d] font-bold"
        >
          D
        </div>
        <div
          class="text-center font-callingstone text-sm md:text-base text-[#c9968d] font-bold"
        >
          L
        </div>
        <div
          class="text-center font-callingstone text-sm md:text-base text-[#c9968d] font-bold"
        >
          M
        </div>
        <div
          class="text-center font-callingstone text-sm md:text-base text-[#c9968d] font-bold"
        >
          M
        </div>
        <div
          class="text-center font-callingstone text-sm md:text-base text-[#c9968d] font-bold"
        >
          J
        </div>
        <div
          class="text-center font-callingstone text-sm md:text-base text-[#c9968d] font-bold"
        >
          V
        </div>
        <div
          class="text-center font-callingstone text-sm md:text-base text-[#c9968d] font-bold"
        >
          S
        </div>
      </div>

      <!-- DÍAS DEL MES -->
      <div class="grid grid-cols-7 gap-1 md:gap-2" id="dias-container"></div>
    </div>
  </div>

  <!-- FLOR ABAJO DERECHA -->
  <img
    src="/imagenes/florabajo.png"
    alt=""
    id="flores-cal"
    class="absolute bottom-0 right-0 w-56 sm:w-44 object-contain pointer-events-none z-20"
  />
</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  const DIA_ESPECIAL = 18;
  const MES_ESPECIAL = 4;
  const AÑO_ESPECIAL = 2026;

  const NOMBRES_MESES = [
    "Enero",
    "Febrero",
    "Marzo",
    "Abril",
    "Mayo",
    "Junio",
    "Julio",
    "Agosto",
    "Septiembre",
    "Octubre",
    "Noviembre",
    "Diciembre",
  ];

  function generarCalendario() {
    const nombreMesEl = document.getElementById("nombre-mes");
    if (nombreMesEl) nombreMesEl.textContent = NOMBRES_MESES[MES_ESPECIAL - 1];

    const primerDia = new Date(AÑO_ESPECIAL, MES_ESPECIAL - 1, 1).getDay();
    const ultimoDia = new Date(AÑO_ESPECIAL, MES_ESPECIAL, 0).getDate();
    const diasContainer = document.getElementById("dias-container");
    if (!diasContainer) return;
    diasContainer.innerHTML = "";

    for (let i = 0; i < primerDia; i++) {
      diasContainer.appendChild(document.createElement("div"));
    }

    for (let dia = 1; dia <= ultimoDia; dia++) {
      const diaDiv = document.createElement("div");
      if (dia === DIA_ESPECIAL) {
        diaDiv.className =
          "aspect-square flex items-center justify-center rounded-lg bg-[#63778d] dia-calendario";
        diaDiv.id = "dia-especial";
        diaDiv.innerHTML = `<span class="font-callingstone text-xl md:text-2xl text-white font-bold">${dia}</span>`;
      } else {
        diaDiv.className =
          "aspect-square flex items-center justify-center rounded-lg hover:bg-[#c9968d]/20 transition-all dia-calendario";
        diaDiv.innerHTML = `<span class="font-callingstone text-sm md:text-base text-[#63778d]">${dia}</span>`;
      }
      diasContainer.appendChild(diaDiv);
    }
  }

  if (typeof window !== "undefined") {
    document.addEventListener("DOMContentLoaded", () => {
      generarCalendario();

      gsap.set("#calendario-onda", { opacity: 0, y: -20 });
      gsap.set("#calendario-card", { opacity: 0, scale: 0.95 });
      gsap.set("#linea-izq", { opacity: 0, scaleX: 0 });
      gsap.set("#linea-der", { opacity: 0, scaleX: 0 });
      gsap.set("#titulo-mes-container h3", { opacity: 0, scale: 0.9 });
      gsap.set(".dia-calendario", { opacity: 0, scale: 0.8 });
      gsap.set("#flores-cal", { opacity: 0, x: 30 });

      ScrollTrigger.create({
        trigger: "#calendario-card",
        start: "top 85%",
        end: "top 20%",
        onEnter: () => {
          const tl = gsap.timeline();
          tl.to(
            "#calendario-onda, #calendario-card, #linea-izq, #linea-der, #titulo-mes-container h3, #flores-cal",
            { opacity: 1, duration: 0.8, ease: "power2.out" },
          )
            .to(
              "#calendario-onda",
              { y: 0, duration: 0.8, ease: "power2.out" },
              "<",
            )
            .to(
              "#calendario-card",
              { scale: 1, duration: 0.8, ease: "back.out(1.3)" },
              "<",
            )
            .to(
              "#linea-izq, #linea-der",
              { scaleX: 1, duration: 0.6, ease: "power2.out" },
              "<",
            )
            .to(
              "#titulo-mes-container h3",
              { scale: 1, duration: 0.6, ease: "back.out(1.3)" },
              "<",
            )
            .to("#flores-cal", { x: 0, duration: 0.8, ease: "power2.out" }, "<")
            .to(
              ".dia-calendario",
              {
                opacity: 1,
                scale: 1,
                duration: 0.4,
                stagger: 0.02,
                ease: "back.out(1.2)",
              },
              "-=0.3",
            );
        },
        onLeaveBack: () => {
          gsap.set("#calendario-onda", { opacity: 0, y: -20 });
          gsap.set("#calendario-card", { opacity: 0, scale: 0.95 });
          gsap.set("#linea-izq", { opacity: 0, scaleX: 0 });
          gsap.set("#linea-der", { opacity: 0, scaleX: 0 });
          gsap.set("#titulo-mes-container h3", { opacity: 0, scale: 0.9 });
          gsap.set(".dia-calendario", { opacity: 0, scale: 0.8 });
          gsap.set("#flores-cal", { opacity: 0, x: 30 });
        },
      });

      gsap.to("#dia-especial", {
        scale: 1.05,
        duration: 2.5,
        ease: "sine.inOut",
        yoyo: true,
        repeat: -1,
        delay: 1.5,
      });
    });
  }
</script>

<style>
  #dia-especial {
    box-shadow: 0 6px 20px rgba(99, 119, 141, 0.4);
    position: relative;
  }
  #dia-especial::after {
    content: "";
    position: absolute;
    inset: -3px;
    border-radius: 0.5rem;
    border: 2px solid rgba(235, 204, 196, 0.5);
    pointer-events: none;
  }
  .dia-calendario:hover {
    transform: translateY(-2px);
  }
</style>
