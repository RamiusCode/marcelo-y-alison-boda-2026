    </div>

    <script>
      import { gsap } from "gsap";
      import { ScrollTrigger } from "gsap/ScrollTrigger";

      gsap.registerPlugin(ScrollTrigger);

      if (typeof window !== "undefined") {
        document.addEventListener("DOMContentLoaded", () => {
          gsap.set("#flores-arriba-despedida", { opacity: 0, y: 20 });
          gsap.set("#card-despedida", { opacity: 0, y: 30 });
          gsap.set("#flores-abajo-despedida", { opacity: 0, y: 20 });

          ScrollTrigger.create({
            trigger: "#flores-arriba-despedida",
            start: "top 85%",
            onEnter: () => {
              const tl = gsap.timeline();
              tl.to(
                "#flores-arriba-despedida",
                { opacity: 1, y: 0, duration: 1, ease: "power2.out" },
                0,
              )
                .to(
                  "#card-despedida",
                  { opacity: 1, y: 0, duration: 1.2, ease: "power2.out" },
                  0.2,
                )
                .to(
                  "#flores-abajo-despedida",
                  { opacity: 1, y: 0, duration: 1, ease: "power2.out" },
                  0.4,
                );

              gsap.to("#linea-decorativa svg", {
                scale: 1.15,
                duration: 2.5,
                ease: "sine.inOut",
                yoyo: true,
                repeat: -1,
                delay: 1.5,
              });
            },
            onLeaveBack: () => {
              gsap.killTweensOf("#linea-decorativa svg");
              gsap.set("#flores-arriba-despedida", { opacity: 0, y: 20 });
              gsap.set("#card-despedida", { opacity: 0, y: 30 });
              gsap.set("#flores-abajo-despedida", { opacity: 0, y: 20 });
            },
          });
        });
      }
    </script>

    <style>
      #card-despedida {
        background: rgba(255, 255, 255, 0.08);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        transition: all 0.3s ease;
      }

      #card-despedida:hover {
        background: rgba(255, 255, 255, 0.12);
        box-shadow: 0 20px 40px rgba(182, 143, 136, 0.15);
        transform: translateY(-4px);
      }

      .boton-confirmar {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        padding: 10px 28px;
        width: 100%;
        max-width: 260px;
        background: #ebccc4;
        color: white;
        border: none;
        border-radius: 50px;
        font-size: 14px;
        font-weight: 600;
        letter-spacing: 0.15em;
        text-decoration: none;
        white-space: nowrap;
        transition: all 0.3s ease;
      }

      .boton-confirmar:hover {
        background: #4e6070;
        box-shadow: 0 4px 16px rgba(99, 119, 141, 0.4);
        transform: translateY(-2px);
      }
    </style>
