---
// src/components/Fecha.astro
---

<section class="py-8 px-4">
  <div class="max-w-2xl mx-auto text-center relative">
    <!-- FLOR IZQUIERDA -->
    <div
      class="absolute left-0 top-1/2 -translate-y-2/3 w-16 pointer-events-none -ml-6 sm:-ml-7 md:-ml-8"
      id="hoja-fecha-izq"
    >
      <img
        src="/imagenes/azullateral.png"
        alt="Flor izquierda"
        class="w-full h-auto object-contain"
      />
    </div>

    <!-- FLOR DERECHA -->
    <div
      class="absolute right-0 top-1/2 -translate-y-2/3 w-16 pointer-events-none -mr-6 sm:-mr-7 md:-mr-8"
      id="hoja-fecha-der"
    >
      <img
        src="/imagenes/azullateral.png"
        alt="Flor derecha"
        class="w-full h-auto object-contain -scale-x-100"
      />
    </div>

    <!-- TEXTO ACOMPAÑANOS -->
    <div class="mb-6" id="texto-invitacion-container">
      <div id="texto-invitacion">
        <p
          class="font-cathylise text-[#63778d] leading-relaxed text-center"
          style="font-size: clamp(2rem, 8vw, 3.5rem);"
        >
          Acompáñanos este día<br />tan especial
        </p>
      </div>
    </div>

    <!-- FECHA -->
    <div class="relative max-w-md mx-auto" id="fecha-evento">
      <div class="flex items-center justify-center gap-4 md:gap-6">
        <!-- SÁBADO -->
        <div class="flex flex-col items-center w-24 md:w-28">
          <div class="w-full h-px bg-[#ebccc4] mb-2"></div>
          <span
            class="font-callingstone text-lg md:text-xl text-[#63778d] uppercase tracking-wider font-bold text-center"
          >
            SÁBADO
          </span>
          <div class="w-full h-px bg-[#ebccc4] mt-2"></div>
        </div>

        <!-- Número -->
        <div
          class="flex items-center justify-center min-w-[80px] md:min-w-[100px]"
        >
          <span
            class="font-charm text-[#ebccc4] font-bold"
            style="font-size: clamp(4rem, 15vw, 6rem);"
          >
            18
          </span>
        </div>

        <!-- ABRIL -->
        <div class="flex flex-col items-center w-24 md:w-28">
          <div class="w-full h-px bg-[#ebccc4] mb-2"></div>
          <span
            class="font-callingstone text-lg md:text-xl text-[#63778d] uppercase tracking-wider font-bold text-center"
          >
            ABRIL
          </span>
          <div class="w-full h-px bg-[#ebccc4] mt-2"></div>
        </div>
      </div>

      <!-- AÑO -->
      <div class="mt-4 flex justify-center" id="anio-evento">
        <p
          class="font-callingstone text-3xl md:text-4xl text-[#63778d] font-bold"
        >
          2026
        </p>
      </div>
    </div>
  </div>
</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  if (typeof window !== "undefined") {
    document.addEventListener("DOMContentLoaded", () => {
      gsap.set("#hoja-fecha-izq", { opacity: 0, x: -30 });
      gsap.set("#hoja-fecha-der", { opacity: 0, x: 30 });
      gsap.set("#texto-invitacion", { opacity: 0, scale: 0.9 });
      gsap.set("#fecha-evento", { opacity: 0, scale: 0.9 });
      gsap.set("#anio-evento", { opacity: 0, scale: 0.9 });

      ScrollTrigger.create({
        trigger: "#texto-invitacion",
        start: "top 85%",
        end: "top 20%",

        onEnter: () => {
          const tl = gsap.timeline();
          tl.to(
            "#hoja-fecha-izq, #hoja-fecha-der, #texto-invitacion, #fecha-evento, #anio-evento",
            { opacity: 1, duration: 1, ease: "power2.out" },
          )
            .to(
              "#hoja-fecha-izq",
              { x: 0, duration: 1, ease: "power2.out" },
              "<",
            )
            .to(
              "#hoja-fecha-der",
              { x: 0, duration: 1, ease: "power2.out" },
              "<",
            )
            .to(
              "#texto-invitacion, #fecha-evento, #anio-evento",
              { scale: 1, duration: 1, ease: "back.out(1.2)" },
              "<",
            );
        },

        onLeaveBack: () => {
          const tl = gsap.timeline();
          tl.to(
            "#hoja-fecha-izq, #hoja-fecha-der, #texto-invitacion, #fecha-evento, #anio-evento",
            { opacity: 0, duration: 0.5, ease: "power2.in" },
          )
            .to(
              "#hoja-fecha-izq",
              { x: -30, duration: 0.5, ease: "power2.in" },
              "<",
            )
            .to(
              "#hoja-fecha-der",
              { x: 30, duration: 0.5, ease: "power2.in" },
              "<",
            )
            .to(
              "#texto-invitacion, #fecha-evento, #anio-evento",
              { scale: 0.9, duration: 0.5, ease: "power2.in" },
              "<",
            );
        },
      });
    });
  }
</script>

<style>
  @media (max-width: 640px) {
    section {
      padding-left: 1rem;
      padding-right: 1rem;
    }
  }
</style>
