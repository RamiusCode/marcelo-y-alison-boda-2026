<!-- CONTENIDO -->
<section
  class="pt-6 pb-12 px-4 relative overflow-hidden"
  id="seccion-vestimenta"
>
  <div class="max-w-xl mx-auto text-center relative z-10">
    <!-- HOJAS LATERALES -->
    <div
      class="absolute left-0 top-1/2 -translate-y-1/2 w-16 sm:w-20 pointer-events-none z-0 -ml-8 sm:-ml-12"
      id="hoja-izq-vestimenta"
    >
      <img
        src="/imagenes/azullateral.png"
        alt=""
        class="w-full h-auto object-contain opacity-80"
      />
    </div>
    <div
      class="absolute right-0 top-1/2 -translate-y-1/2 w-16 sm:w-20 pointer-events-none z-0 -mr-8 sm:-mr-12"
      id="hoja-der-vestimenta"
    >
      <img
        src="/imagenes/azullateral.png"
        alt=""
        class="w-full h-auto object-contain opacity-80 scale-x-[-1]"
      />
    </div>

    <!-- SEPARADOR SUPERIOR -->
    <!-- <div class="flex justify-center mb-6" id="separador-superior">
      <img
        src="/imagenes/Separadores.webp"
        alt=""
        class="w-32 md:w-40 h-auto object-contain opacity-90"
      />
    </div> -->

    <!-- ICONO -->
    <div class="flex justify-center mb-4" id="imagen-vestimenta">
      <img
        src="/imagenes/CodigoVestimenta.webp"
        alt="Código de vestimenta"
        class="w-16 md:w-24 h-auto object-contain icono-color"
      />
    </div>

    <!-- FORMAL -->
    <div class="mb-3" id="descripcion-vestimenta">
      <p
        class="font-callingstone text-[#63778d] uppercase tracking-widest font-bold font-base"
      >
        Formal
      </p>
    </div>

    <!-- NOTA -->
    <div id="nota-vestimenta">
      <p
        class="font-callingstone text-[#c9968d] tracking-widest mx-6 leading-relaxed text-base"
      >
        El blanco está reservado <br /> para la novia
      </p>
    </div>
  </div>
</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  gsap.registerPlugin(ScrollTrigger);

  if (typeof window !== "undefined") {
    document.addEventListener("DOMContentLoaded", () => {
      gsap.set("#vestimenta-onda", { opacity: 0, y: -20 });
      gsap.set("#separador-superior", { opacity: 0, y: -20 });
      gsap.set("#imagen-vestimenta", { opacity: 0, scale: 0.8 });
      gsap.set("#descripcion-vestimenta", { opacity: 0, y: 20 });
      gsap.set("#nota-vestimenta", { opacity: 0, y: 20 });
      gsap.set("#hoja-izq-vestimenta", { opacity: 0, x: -40 });
      gsap.set("#hoja-der-vestimenta", { opacity: 0, x: 40 });

      ScrollTrigger.create({
        trigger: "#seccion-vestimenta",
        start: "top 85%",
        onEnter: () => {
          const tl = gsap.timeline();
          tl.to("#vestimenta-onda", {
            opacity: 1,
            y: 0,
            duration: 0.8,
            ease: "power2.out",
          })
            .to(
              "#separador-superior",
              { opacity: 1, y: 0, duration: 0.8, ease: "power2.out" },
              "-=0.4",
            )
            .to(
              "#imagen-vestimenta",
              { opacity: 1, scale: 1, duration: 1, ease: "back.out(1.5)" },
              "-=0.4",
            )
            .to(
              "#descripcion-vestimenta",
              { opacity: 1, y: 0, duration: 0.8, ease: "power2.out" },
              "-=0.6",
            )
            .to(
              "#nota-vestimenta",
              { opacity: 1, y: 0, duration: 0.8, ease: "power2.out" },
              "-=0.6",
            )
            .to(
              "#hoja-izq-vestimenta, #hoja-der-vestimenta",
              { opacity: 1, x: 0, duration: 1, ease: "power2.out" },
              "-=0.8",
            );

          gsap.to("#imagen-vestimenta", {
            scale: 1.05,
            duration: 2.5,
            ease: "sine.inOut",
            yoyo: true,
            repeat: -1,
            delay: 1.5,
          });
        },
        onLeaveBack: () => {
          gsap.set("#vestimenta-onda", { opacity: 0, y: -20 });
          gsap.set("#separador-superior", { opacity: 0, y: -20 });
          gsap.set("#imagen-vestimenta", { opacity: 0, scale: 0.8 });
          gsap.set("#descripcion-vestimenta", { opacity: 0, y: 20 });
          gsap.set("#nota-vestimenta", { opacity: 0, y: 20 });
          gsap.set("#hoja-izq-vestimenta", { opacity: 0, x: -40 });
          gsap.set("#hoja-der-vestimenta", { opacity: 0, x: 40 });
        },
      });
    });
  }
</script>

<style>
  .icono-color {
    filter: brightness(0) saturate(100%) invert(46%) sepia(40%) saturate(400%)
      hue-rotate(170deg) brightness(90%) contrast(90%);
  }
</style>
