<!-- FECHA: DIA | LUGAR | HORA -->
<section class="pb-16 pt-6 px-4" id="seccion-fecha">
  <div class="max-w-lg mx-auto" id="fecha-contenido">
    <div class="flex items-start justify-center gap-0">
      <!-- DIA -->
      <div class="flex flex-col items-center flex-1">
        <p
          class="font-callingstone text-[#63778d] uppercase tracking-widest text-sm sm:text-base font-bold mb-2"
        >
          DÍA
        </p>
        <p
          class="font-charm text-[#63778d]"
          style="font-size: clamp(1.4rem, 5vw, 2rem);"
        >
          18
        </p>
        <p
          class="font-callingstone text-[#63778d] text-sm sm:text-base font-bold"
        >
          ABRIL
        </p>
      </div>

      <div class="w-px self-stretch bg-[#ebccc4] mx-2 sm:mx-4"></div>

      <!-- LUGAR -->
      <div class="flex flex-col items-center flex-1">
        <p
          class="font-callingstone text-[#63778d] uppercase tracking-widest text-sm sm:text-base font-bold mb-2"
        >
          Lugar
        </p>
        <p
          class="font-cathylise text-[#63778d] text-center leading-tight"
          style="font-size: clamp(1.2rem, 4vw, 1.6rem);"
        >
          Catedral<br />Castrense
        </p>
      </div>

      <div class="w-px self-stretch bg-[#ebccc4] mx-2 sm:mx-4"></div>

      <!-- HORA -->
      <div class="flex flex-col items-center flex-1">
        <p
          class="font-callingstone text-[#63778d] uppercase tracking-widest text-sm sm:text-base font-bold mb-2"
        >
          Hora
        </p>
        <p
          class="font-cathylise text-[#63778d]"
          style="font-size: clamp(1.4rem, 5vw, 2rem);"
        >
          14:00
        </p>
        <p class="font-callingstone text-[#63778d] text-sm sm:text-base">
          p.m.
        </p>
      </div>
    </div>
  </div>
</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  if (typeof window !== "undefined") {
    document.addEventListener("DOMContentLoaded", () => {
      gsap.set("#fecha-onda", { opacity: 0, y: -20 });
      gsap.set("#fecha-contenido", { opacity: 0, y: 30 });

      ScrollTrigger.create({
        trigger: "#seccion-fecha",
        start: "top 85%",
        onEnter: () => {
          gsap.to("#fecha-onda", {
            opacity: 1,
            y: 0,
            duration: 0.8,
            ease: "power2.out",
          });
          gsap.to("#fecha-contenido", {
            opacity: 1,
            y: 0,
            duration: 1,
            ease: "power2.out",
            delay: 0.3,
          });
        },
        onLeaveBack: () => {
          gsap.set("#fecha-onda", { opacity: 0, y: -20 });
          gsap.set("#fecha-contenido", { opacity: 0, y: 30 });
        },
      });
    });
  }
</script>
