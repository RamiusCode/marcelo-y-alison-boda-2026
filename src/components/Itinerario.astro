<!-- CONTENIDO ITINERARIO -->
<section class="px-4 relative overflow-hidden py-4" id="seccion-itinerario">
  <div class="max-w-sm mx-auto relative">
    <!-- Línea central vertical -->
    <div
      class="absolute left-1/2 -translate-x-1/2 top-0 bottom-0 w-[2px] bg-[#63778d] linea-central opacity-0"
    >
    </div>

    <div id="eventos-container">
      <!-- CEREMONIA RELIGIOSA — derecha -->
      <div
        class="evento-item opacity-0 flex items-center"
        style="min-height:60px;"
      >
        <div class="flex-1"></div>
        <div class="relative flex-shrink-0 flex items-center" style="width:0;">
          <div
            class="w-3 h-3 rounded-full border-2 border-[#63778d] bg-white punto-item absolute -translate-x-1/2 z-10"
          >
          </div>
          <div
            class="absolute left-[6px] h-[2px] bg-[#63778d]"
            style="width:24px;"
          >
          </div>
        </div>
        <div
          class="flex-1 flex flex-col items-center texto-der"
          style="padding-left:36px;"
        >
          <img
            src="/iconos/iglesia.png"
            alt="Ceremonia Religiosa"
            class="w-9 h-9 object-contain icono-filter mb-0.5"
          />
          <p
            class="font-callingstone text-[#63778d] font-bold uppercase tracking-widest text-xs text-center leading-tight"
          >
            CEREMONIA<br />RELIGIOSA
          </p>
          <p
            class="font-callingstone text-[#c9968d] tracking-widest"
            style="font-size:0.65rem;"
          >
            4:00 P.M.
          </p>
        </div>
      </div>

      <div class="h-4"></div>

      <!-- BRINDIS — izquierda -->
      <div
        class="evento-item opacity-0 flex items-center"
        style="min-height:60px;"
      >
        <div
          class="flex-1 flex flex-col items-center texto-izq"
          style="padding-right:36px;"
        >
          <img
            src="/iconos/brindis.png"
            alt="Brindis"
            class="w-9 h-9 object-contain icono-filter mb-0.5"
          />
          <p
            class="font-callingstone text-[#63778d] font-bold uppercase tracking-widest text-xs"
          >
            BRINDIS
          </p>
          <p
            class="font-callingstone text-[#c9968d] tracking-widest"
            style="font-size:0.65rem;"
          >
            5:00 P.M.
          </p>
        </div>
        <div class="relative flex-shrink-0 flex items-center" style="width:0;">
          <div
            class="w-3 h-3 rounded-full border-2 border-[#63778d] bg-white punto-item absolute -translate-x-1/2 z-10"
          >
          </div>
          <div
            class="absolute h-[2px] bg-[#63778d]"
            style="width:24px; right:6px;"
          >
          </div>
        </div>
        <div class="flex-1"></div>
      </div>

      <div class="h-4"></div>

      <!-- PARTY — derecha -->
      <div
        class="evento-item opacity-0 flex items-center"
        style="min-height:60px;"
      >
        <div class="flex-1"></div>
        <div class="relative flex-shrink-0 flex items-center" style="width:0;">
          <div
            class="w-3 h-3 rounded-full border-2 border-[#63778d] bg-white punto-item absolute -translate-x-1/2 z-10"
          >
          </div>
          <div
            class="absolute left-[6px] h-[2px] bg-[#63778d]"
            style="width:24px;"
          >
          </div>
        </div>
        <div
          class="flex-1 flex flex-col items-center texto-der"
          style="padding-left:36px;"
        >
          <img
            src="/iconos/musica.png"
            alt="Party"
            class="w-9 h-9 object-contain icono-filter mb-0.5"
          />
          <p
            class="font-callingstone text-[#63778d] font-bold uppercase tracking-widest text-xs"
          >
            PARTY
          </p>
          <p
            class="font-callingstone text-[#c9968d] tracking-widest"
            style="font-size:0.65rem;"
          >
            5:30 P.M.
          </p>
        </div>
      </div>

      <div class="h-4"></div>

      <!-- CENA — izquierda -->
      <div
        class="evento-item opacity-0 flex items-center"
        style="min-height:60px;"
      >
        <div
          class="flex-1 flex flex-col items-center texto-izq"
          style="padding-right:36px;"
        >
          <img
            src="/iconos/cena.png"
            alt="Cena"
            class="w-9 h-9 object-contain icono-filter mb-0.5"
          />
          <p
            class="font-callingstone text-[#63778d] font-bold uppercase tracking-widest text-xs"
          >
            CENA
          </p>
          <p
            class="font-callingstone text-[#c9968d] tracking-widest"
            style="font-size:0.65rem;"
          >
            7:00 P.M.
          </p>
        </div>
        <div class="relative flex-shrink-0 flex items-center" style="width:0;">
          <div
            class="w-3 h-3 rounded-full border-2 border-[#63778d] bg-white punto-item absolute -translate-x-1/2 z-10"
          >
          </div>
          <div
            class="absolute h-[2px] bg-[#63778d]"
            style="width:24px; right:6px;"
          >
          </div>
        </div>
        <div class="flex-1"></div>
      </div>

      <div class="h-4"></div>

      <!-- TORTA — derecha -->
      <div
        class="evento-item opacity-0 flex items-center"
        style="min-height:60px;"
      >
        <div class="flex-1"></div>
        <div class="relative flex-shrink-0 flex items-center" style="width:0;">
          <div
            class="w-3 h-3 rounded-full border-2 border-[#63778d] bg-white punto-item absolute -translate-x-1/2 z-10"
          >
          </div>
          <div
            class="absolute left-[6px] h-[2px] bg-[#63778d]"
            style="width:24px;"
          >
          </div>
        </div>
        <div
          class="flex-1 flex flex-col items-center texto-der"
          style="padding-left:36px;"
        >
          <img
            src="/iconos/torta.png"
            alt="Torta"
            class="w-9 h-9 object-contain icono-filter mb-0.5"
          />
          <p
            class="font-callingstone text-[#63778d] font-bold uppercase tracking-widest text-xs"
          >
            TORTA
          </p>
          <p
            class="font-callingstone text-[#c9968d] tracking-widest"
            style="font-size:0.65rem;"
          >
            9:30 P.M.
          </p>
        </div>
      </div>

      <div class="h-4"></div>

      <!-- DESPEDIDA — izquierda -->
      <div
        class="evento-item opacity-0 flex items-center"
        style="min-height:60px;"
      >
        <div
          class="flex-1 flex flex-col items-center texto-izq"
          style="padding-right:36px;"
        >
          <img
            src="/iconos/despedida.png"
            alt="Despedida"
            class="w-9 h-9 object-contain icono-filter mb-0.5"
          />
          <p
            class="font-callingstone text-[#63778d] font-bold uppercase tracking-widest text-xs text-center leading-tight"
          >
            DESPEDIDA<br />NOVIOS
          </p>
          <p
            class="font-callingstone text-[#c9968d] tracking-widest"
            style="font-size:0.65rem;"
          >
            11:30 P.M.
          </p>
        </div>
        <div class="relative flex-shrink-0 flex items-center" style="width:0;">
          <div
            class="w-3 h-3 rounded-full border-2 border-[#63778d] bg-white punto-item absolute -translate-x-1/2 z-10"
          >
          </div>
          <div
            class="absolute h-[2px] bg-[#63778d]"
            style="width:24px; right:6px;"
          >
          </div>
        </div>
        <div class="flex-1"></div>
      </div>
    </div>
  </div>
</section>

<style>
  .icono-filter {
    filter: brightness(0) saturate(100%) invert(46%) sepia(40%) saturate(400%)
      hue-rotate(170deg) brightness(90%) contrast(90%);
  }
  .punto-item {
    box-shadow: 0 0 0 2px rgba(99, 119, 141, 0.15);
  }
</style>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  gsap.registerPlugin(ScrollTrigger);

  const initItinerario = () => {
    gsap.set("#itinerario-onda", { opacity: 0, y: -20 });
    gsap.set(".linea-central", {
      opacity: 0,
      scaleY: 0,
      transformOrigin: "top center",
    });
    gsap.set(".punto-item", { opacity: 0, scale: 0 });
    gsap.set(".evento-item", { opacity: 0 });
    gsap.set(".texto-izq", { x: -40 });
    gsap.set(".texto-der", { x: 40 });

    ScrollTrigger.create({
      trigger: "#itinerario-onda",
      start: "top 85%",
      onEnter: () => {
        gsap.to("#itinerario-onda", {
          opacity: 1,
          y: 0,
          duration: 0.8,
          ease: "power2.out",
        });
      },
      onLeaveBack: () => {
        gsap.set("#itinerario-onda", { opacity: 0, y: -20 });
      },
    });

    ScrollTrigger.create({
      trigger: "#eventos-container",
      start: "top 85%",
      onEnter: () => {
        const tl = gsap.timeline();
        tl.to(".linea-central", {
          opacity: 1,
          scaleY: 1,
          duration: 1.5,
          ease: "power2.out",
        })
          .to(
            ".punto-item",
            {
              opacity: 1,
              scale: 1,
              duration: 0.4,
              stagger: 0.12,
              ease: "back.out(1.7)",
            },
            "-=1.2",
          )
          .to(
            ".evento-item",
            { opacity: 1, duration: 0.5, stagger: 0.12, ease: "power2.out" },
            "-=1.5",
          )
          .to(
            ".texto-izq",
            { x: 0, duration: 0.5, stagger: 0.12, ease: "power2.out" },
            "-=1.8",
          )
          .to(
            ".texto-der",
            { x: 0, duration: 0.5, stagger: 0.12, ease: "power2.out" },
            "-=1.8",
          );
      },
      onLeaveBack: () => {
        gsap.set(".linea-central", { opacity: 0, scaleY: 0 });
        gsap.set(".punto-item", { opacity: 0, scale: 0 });
        gsap.set(".evento-item", { opacity: 0 });
        gsap.set(".texto-izq", { x: -40 });
        gsap.set(".texto-der", { x: 40 });
      },
    });
  };

  document.addEventListener("DOMContentLoaded", initItinerario);
  document.addEventListener("astro:page-load", initItinerario);
</script>
