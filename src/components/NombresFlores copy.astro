<section class="relative text-black w-full">
    <!-- ═══════════════════════════════════════════════════════════ -->
    <!-- 🌸 SECCIÓN 1: FLORES SUPERIORES + TÍTULO + ANILLOS         -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <div class="relative w-full overflow-visible" id="flores-superiores">
        <!-- 🌸 Contenedor de flores superiores (izquierda y derecha) -->
        <div class="relative w-full flex justify-between items-start">
            <!-- Flores izquierda superior -->
            <div
                id="flores-sup-izq"
                class="w-32 sm:w-36 md:w-40 lg:w-36 flex-shrink-0"
            >
                <img
                    src="/imagenes/FloresEsquina.webp"
                    alt="Flores superiores izquierda"
                    class="w-full h-auto object-contain"
                    style="opacity: 1 !important;"
                />
            </div>

            <!-- Flores derecha superior -->
            <div
                id="flores-sup-der"
                class="w-32 sm:w-36 md:w-40 lg:w-44 flex-shrink-0"
            >
                <img
                    src="/imagenes/FloresEsquina.webp"
                    alt="Flores superiores derecha"
                    class="w-full h-auto object-contain scale-x-[-1]"
                    style="opacity: 1 !important;"
                />
            </div>
        </div>

        <!-- 💍 Título "Nos Casamos" (posición absoluta, centrado) -->
        <div
            class="absolute pt-10 left-1/2 transform -translate-x-1/2 top-[20px] sm:top-[25px] md:top-[30px] lg:top-[35px] z-50"
            id="titulo-container"
        >
            <h1
                class="font-great-vibes text-3xl sm:text-4xl md:text-5xl lg:text-6xl text-[#ecccc4] font-normal tracking-wide whitespace-nowrap"
                id="titulo"
            >
                ¡Nos Casamos!
            </h1>
        </div>

        <!-- 💎 Anillos (posición absoluta, debajo del título) -->
        <div
            class="absolute left-1/2 transform -translate-x-1/2 top-[120px] sm:top-[130px] md:top-[190px] lg:top-[190px] z-50"
            id="anillos"
        >
            <img
                src="/imagenes/Anillos.webp"
                alt="Anillos de boda"
                class="w-[144px] h-auto sm:w-40 md:w-40 lg:w-48 object-contain mx-auto"
            />
        </div>
    </div>

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!-- 💑 SECCIÓN 2: NOMBRES DE LOS NOVIOS                         -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <div class="relative w-full pt-40 sm:pt-24 md:pt-40 lg:pt-48">
        <div class="flex justify-center w-full">
            <!-- 🌺 FLORES DORADAS IZQUIERDA (posición absoluta, lado izquierdo) -->
            <div
                id="flores-doradas-izq"
                class="absolute left-0 top-[40%] transform -translate-y-1/2 flex-shrink-0 z-20"
            >
                <img
                    src="/imagenes/RosaDorada.webp"
                    alt="Flores doradas izquierda"
                    class="w-12 h-auto sm:w-20 md:w-24 lg:w-44 object-contain"
                />
            </div>

            <!-- 🌺 FLORES DORADAS DERECHA (posición absoluta, lado derecho) -->
            <div
                id="flores-doradas-der"
                class="absolute right-0 top-[40%] transform -translate-y-1/2 flex-shrink-0 z-20"
            >
                <img
                    src="/imagenes/RosaDorada.webp"
                    alt="Flores doradas derecha"
                    class="w-12 h-auto sm:w-20 md:w-24 lg:w-44 object-contain scale-x-[-1]"
                />
            </div>

            <!-- 📝 Contenedor centrado de nombres -->
            <div class="text-center z-10 max-w-4xl w-full">
                <div class="relative mb-8 w-full" id="nombres-container">
                    <div class="relative z-30">
                        <!-- 👨 Nombre del novio -->
                        <h2
                            class="font-great-vibes text-6xl sm:text-7xl md:text-8xl lg:text-9xl text-[#62788d] tracking-wide mb-2"
                            id="nombre-novio"
                        >
                        </h2>

                        <!-- ⚭ Símbolo & -->
                        <div
                            class="text-[#ecccc4] text-5xl sm:text-6xl md:text-7xl font-charm my-4"
                            id="ampersand"
                        >
                            &
                        </div>

                        <!-- 👰 Nombre de la novia -->
                        <h2
                            class="font-great-vibes text-6xl sm:text-7xl md:text-8xl lg:text-9xl text-[#62788d] tracking-wide mt-2"
                            id="nombre-novia"
                        >
                        </h2>
                    </div>
                </div>
            </div>
        </div>

        <!-- ═══════════════════════════════════════════════════════════ -->
        <!-- ✨ SECCIÓN 3: SEPARADOR CON BRILLOS LATERALES               -->
        <!-- ═══════════════════════════════════════════════════════════ -->
        <div
            class="relative w-full overflow-visible flex justify-between"
            id="separador-container"
        >
            <!-- ✨ Brillo IZQUIERDA -->
            <div
                id="flores-izq"
                class="flex-shrink-0 z-0 lg:absolute lg:left-0"
            >
                <img
                    src="/imagenes/Brillo.webp"
                    alt="Flores izquierda"
                    class="w-10 h-auto sm:w-24 md:w-32 lg:w-40 object-contain"
                />
            </div>

            <!-- ═══ SEPARADOR (centro) ═══ -->
            <div class="flex-grow mx-4 sm:mx-6 md:mx-8" id="separador-inferior">
                <img
                    src="/imagenes/Separadores.webp"
                    alt="Separador decorativo"
                    class="w-[144px] sm:w-48 md:w-48 lg:w-56 h-auto object-contain block mx-auto"
                />
            </div>

            <!-- ✨ Brillo DERECHA -->
            <div
                id="flores-der"
                class="flex-shrink-0 z-0 lg:absolute lg:right-0"
            >
                <img
                    src="/imagenes/Brillo.webp"
                    alt="Flores derecha"
                    class="w-10 h-auto sm:w-24 md:w-32 lg:w-40 object-contain scale-x-[-1]"
                />
            </div>
        </div>
    </div>
</section>

<!-- ═══════════════════════════════════════════════════════════ -->
<!-- 🎬 ANIMACIONES CON GSAP                                     -->
<!-- ═══════════════════════════════════════════════════════════ -->
<script>
    import { gsap } from "gsap";

    document.addEventListener("DOMContentLoaded", () => {
        console.log(
            "🎊 Iniciando animaciones de boda - TODAS AL MISMO TIEMPO...",
        );

        // ═══ FLORES SUPERIORES ═══
        gsap.fromTo(
            "#flores-sup-izq",
            { opacity: 0, x: -100 },
            { opacity: 1, x: 0, duration: 0.8, ease: "power2.out", delay: 0 },
        );

        gsap.fromTo(
            "#flores-sup-der",
            { opacity: 0, x: 100 },
            { opacity: 1, x: 0, duration: 0.8, ease: "power2.out", delay: 0 },
        );

        // ═══ TÍTULO "NOS CASAMOS" ═══
        gsap.fromTo(
            "#titulo",
            { opacity: 0, y: -40 },
            { opacity: 1, y: 0, duration: 0.8, ease: "power2.out", delay: 0.1 },
        );

        // ═══ ANILLOS ═══
        gsap.fromTo(
            "#anillos",
            { opacity: 0, scale: 0.5 },
            {
                opacity: 1,
                scale: 1,
                duration: 0.8,
                ease: "back.out(1.4)",
                delay: 0.2,
            },
        );

        // Rotación suave continua de los anillos
        gsap.to("#anillos", {
            rotation: 5,
            duration: 3,
            ease: "sine.inOut",
            yoyo: true,
            repeat: -1,
            delay: 1,
        });

        // ═══ FUNCIÓN PARA ANIMAR NOMBRES LETRA POR LETRA ═══
        function animarNombre(elementId, texto, delay = 0) {
            const contenedor = document.getElementById(elementId);
            if (!contenedor) return;

            contenedor.innerHTML = texto
                .split("")
                .map(
                    (letra, index) =>
                        `<span class="letra-cascada" style="
                            --i: ${index};
                            opacity: 0; 
                            display: inline-block; 
                            transform: translateY(20px) scale(0.8);
                            filter: blur(2px);
                        ">${letra === " " ? "&nbsp;" : letra}</span>`,
                )
                .join("");

            gsap.to(`#${elementId} .letra-cascada`, {
                opacity: 1,
                y: 0,
                scale: 1,
                filter: "blur(0px)",
                duration: 0.6,
                ease: "power2.out",
                stagger: { each: 0.04, from: "start" },
                delay: delay,
            });
        }

        // ═══ NOMBRE DEL NOVIO ═══
        animarNombre("nombre-novio", "Marcelo", 0.3);

        // ═══ SÍMBOLO & ═══
        gsap.fromTo(
            "#ampersand",
            { opacity: 0, scale: 0.7 },
            {
                opacity: 1,
                scale: 1,
                duration: 0.6,
                ease: "back.out(1.5)",
                delay: 0.5,
            },
        );

        // ═══ NOMBRE DE LA NOVIA ═══
        animarNombre("nombre-novia", "Alison", 0.6);

        // ═══ FLORES DORADAS ═══
        gsap.fromTo(
            "#flores-doradas-izq",
            { opacity: 0, x: -100 },
            { opacity: 1, x: 0, duration: 0.8, ease: "power2.out", delay: 0.4 },
        );

        gsap.fromTo(
            "#flores-doradas-der",
            { opacity: 0, x: 100 },
            { opacity: 1, x: 0, duration: 0.8, ease: "power2.out", delay: 0.4 },
        );

        // ═══ BRILLOS LATERALES ═══
        gsap.fromTo(
            "#flores-izq",
            { opacity: 0, x: -100, scale: 0.9 },
            {
                opacity: 1,
                x: 0,
                scale: 1,
                duration: 0.8,
                ease: "power2.out",
                delay: 0.7,
            },
        );

        gsap.fromTo(
            "#flores-der",
            { opacity: 0, x: 100, scale: 0.9 },
            {
                opacity: 1,
                x: 0,
                scale: 1,
                duration: 0.8,
                ease: "power2.out",
                delay: 0.7,
            },
        );

        // ═══ SEPARADOR (misma animación que anillos) ═══
        gsap.fromTo(
            "#separador-inferior",
            { opacity: 0, scale: 0.5 },
            {
                opacity: 1,
                scale: 1,
                duration: 0.8,
                ease: "back.out(1.4)",
                delay: 0.8,
            },
        );

        // ═══ EFECTO PULSANTE EN BRILLOS ═══
        gsap.to("#flores-izq", {
            opacity: 0.8,
            scale: 1.05,
            duration: 2,
            ease: "sine.inOut",
            yoyo: true,
            repeat: -1,
            delay: 2,
        });

        gsap.to("#flores-der", {
            opacity: 0.8,
            scale: 1.05,
            duration: 2,
            ease: "sine.inOut",
            yoyo: true,
            repeat: -1,
            delay: 2,
        });

        console.log("✨ Animaciones de boda completadas en ~1.5 segundos!");
    });
</script>

<!-- ═══════════════════════════════════════════════════════════ -->
<!-- 🎨 ESTILOS CSS                                              -->
<!-- ═══════════════════════════════════════════════════════════ -->
<style>
    /* Forzar opacidad completa en flores */
    #flores-superiores img,
    #separador-inferior,
    #separador-inferior img {
        opacity: 1 !important;
    }

    /* Efecto hover en letras */
    .letra-cascada {
        transition: all 0.3s ease;
        will-change: transform, opacity, filter;
        position: relative;
    }

    .letra-cascada:hover {
        transform: translateY(-3px) scale(1.08) !important;
        text-shadow: 0 0 15px rgba(201, 169, 97, 0.4) !important;
    }

    /* Eliminar padding en móviles */
    @media (max-width: 640px) {
        section {
            padding-left: 0 !important;
            padding-right: 0 !important;
        }
    }
</style>
