---
// FloresAbajo.astro
---

<section class="relative w-full overflow-hidden pb-0 pt-8 px-4">
    <!-- TEXTO "TE ESPERAMOS" -->
    <div class="relative text-center mb-12" id="texto-esperamos-container">
        <h2
            id="texto-esperamos"
            class="font-callingstone text-[#63778d] tracking-[0.25em] uppercase text-xl"
        >
            Te esperamos
        </h2>
    </div>

    <!-- ONDA ROSADA + FLORES LATERALES + LOGO -->
    <div class="relative w-full" id="onda-final-container">
        <!-- FLORES LATERALES — detrás z-0, subidas -->
        <div
            class="absolute z-0 pointer-events-none"
            style="bottom: 30%; left: 0;"
            id="flor-lat-izq"
        >
            <img
                src="/imagenes/late.png"
                alt=""
                class="w-24 sm:w-32 h-auto object-contain"
            />
        </div>
        <div
            class="absolute z-0 pointer-events-none"
            style="bottom: 30%; right: 0;"
            id="flor-lat-der"
        >
            <img
                src="/imagenes/late.png"
                alt=""
                class="w-24 sm:w-32 h-auto object-contain scale-x-[-1]"
            />
        </div>

        <!-- ONDA SVG — curvas suaves, no exageradas -->
        <svg
            viewBox="0 0 1080 280"
            preserveAspectRatio="none"
            xmlns="http://www.w3.org/2000/svg"
            style="width:100%; display:block; height: clamp(240px, 40vw, 320px); position:relative; z-index:10;"
            id="onda-svg"
        >
            <path
                d="
        M 0,100 20,97 40,91 60,83 80,75 100,68 120,64 140,62 160,63 180,67 200,73 220,79 240,85 260,90 280,93 300,94 320,92 340,88 360,82 380,76 400,71 420,68 440,67 460,68 480,72 500,77 520,83 540,87 560,90 580,91 600,90 620,87 640,82 660,76 680,71 700,68 720,67 740,68 760,72 780,77 800,83 820,88 840,92 860,94 880,93 900,90 920,85 940,79 960,73 980,68 1000,64 1020,63 1040,66 1060,72 1079,80
        L 1079,280 0,280 Z
                "
                fill="#ebccc4"></path>
        </svg>

        <!-- LOGO centrado dinámicamente -->
        <div class="absolute z-20" id="logo-final">
            <img
                src="/imagenes/logo.png"
                alt="Logo M&A"
                class="w-28 sm:w-32 md:w-36 object-contain"
            />
        </div>
    </div>
</section>

<script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";
    gsap.registerPlugin(ScrollTrigger);

    if (typeof window !== "undefined") {
        document.addEventListener("DOMContentLoaded", () => {
            const svg = document.getElementById("onda-svg");
            const logo = document.getElementById("logo-final") as HTMLElement;

            function centrarLogo() {
                if (!svg || !logo) return;
                const svgRect = svg.getBoundingClientRect();
                const logoH = logo.getBoundingClientRect().height;
                const logoW = logo.getBoundingClientRect().width;
                const ondaTopPct = 100 / 280;
                const ondaTopPx = svgRect.height * ondaTopPct;
                const zonaRosada = svgRect.height - ondaTopPx;
                logo.style.top = `${ondaTopPx + (zonaRosada - logoH) / 2}px`;
                logo.style.left = `${svgRect.width / 2 - logoW / 2}px`;
                logo.style.transform = "none";
            }

            centrarLogo();
            window.addEventListener("resize", centrarLogo);

            gsap.set("#texto-esperamos", { opacity: 0, y: -10 });
            gsap.set("#onda-svg", { opacity: 0, y: 40 });
            gsap.set("#logo-final", { opacity: 0, scale: 0.7 });
            gsap.set("#flor-lat-izq", { opacity: 0, x: -40 });
            gsap.set("#flor-lat-der", { opacity: 0, x: 40 });

            ScrollTrigger.create({
                trigger: "#texto-esperamos-container",
                start: "top 85%",
                onEnter: () => {
                    const tl = gsap.timeline();
                    tl.to(
                        "#texto-esperamos",
                        { opacity: 1, y: 0, duration: 0.9, ease: "power2.out" },
                        0,
                    )
                        .to(
                            "#onda-svg",
                            {
                                opacity: 1,
                                y: 0,
                                duration: 1,
                                ease: "power2.out",
                            },
                            0.5,
                        )
                        .to(
                            "#flor-lat-izq",
                            {
                                opacity: 1,
                                x: 0,
                                duration: 1,
                                ease: "power2.out",
                            },
                            0.7,
                        )
                        .to(
                            "#flor-lat-der",
                            {
                                opacity: 1,
                                x: 0,
                                duration: 1,
                                ease: "power2.out",
                            },
                            0.7,
                        )
                        .to(
                            "#logo-final",
                            {
                                opacity: 1,
                                scale: 1,
                                duration: 1,
                                ease: "back.out(1.5)",
                            },
                            0.9,
                        );
                },
            });
        });
    }
</script>

<style>
    section {
        padding-left: 0 !important;
        padding-right: 0 !important;
        padding-bottom: 0 !important;
    }
</style>
