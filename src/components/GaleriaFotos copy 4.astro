        preserveAspectRatio="none"
        xmlns="http://www.w3.org/2000/svg"
        style="width:100%; display:block; height: clamp(140px, 35vw, 280px);"
    >
        <path
            d="
      M 0,33 10,31 20,30 30,27 40,24 50,22 60,19 70,15 80,13 90,10 100,9 110,8 120,8 130,9 140,10 150,12 160,14 170,17 180,20 190,23 200,26 210,28 220,30 230,32 240,33 250,34 260,34 270,34 280,32 290,31 300,28 310,26 320,23 330,19 340,16 350,13 360,11 370,9 380,8 390,8 400,7 410,8 420,8 430,10 440,11 450,13 460,16 470,19 480,23 490,26 500,28 510,30 520,32 530,33 540,34 550,34 560,34 570,33 580,31 590,30 600,27 610,24 620,21 630,18 640,15 650,13 660,11 670,10 680,10 690,9 700,10 710,10 720,11 730,13 740,15 750,17 760,21 770,23 780,26 790,28 800,30 810,30 820,31 830,31 840,31 850,30 860,28 870,27 880,24 890,22 900,19 910,17 920,14 930,11 940,10 950,8 960,8 970,7 980,7 990,8 1000,8 1010,10 1020,11 1030,13 1040,15 1050,18 1060,21 1070,24 1079,28
      L 1079,349 1070,346 1060,342 1050,339 1040,337 1030,334 1020,332 1010,331 1000,330 990,329 980,329 970,329 960,329 950,330 940,331 930,333 920,335 910,338 900,341 890,344 880,346 870,349 860,350 850,352 840,352 830,353 820,352 810,352 800,351 790,349 780,346 770,344 760,341 750,337 740,335 730,332 720,331 710,330 700,329 690,329 680,329 670,330 660,331 650,332 640,335 630,337 620,341 610,343 600,346 590,348 580,350 570,352 560,352 550,353 540,353 530,352 520,351 510,350 500,348 490,345 480,342 470,339 460,337 450,334 440,332 430,331 420,330 410,330 400,330 390,331 380,331 370,333 360,335 350,337 340,341 330,343 320,346 310,348 300,350 290,352 280,352 270,353 260,353 250,352 240,351 230,350 220,348 210,346 200,343 190,341 180,337 170,335 160,333 150,331 140,330 130,329 120,329 110,328 100,329 90,330 80,330 70,331 60,333 50,335 40,337 30,340 20,343 10,346 0,349
      Z
    "
            fill="#ebccc4"></path>
        <foreignObject x="80" y="50" width="920" height="260">
            <div
                xmlns="http://www.w3.org/1999/xhtml"
                style="display:flex; align-items:center; justify-content:center; height:100%; text-align:center;"
            >
                <p
                    class="font-callingstone text-[#63778d] uppercase font-bold text-[30px] sm:text-2xl md:text-3xl tracking-[0.19em]"
                >
                    Nuestra Historia
                </p>
            </div>
        </foreignObject>
    </svg>
</section>

<!-- CONTENIDO -->
<section class="py-6 px-4 relative overflow-hidden" id="seccion-galeria">
    <div class="max-w-sm mx-auto relative z-10">
        <!-- Línea decorativa -->
        <div class="flex items-center justify-center gap-3 mb-6">
            <div
                style="height:1px; width:60px; background: linear-gradient(to right, transparent, #ebccc4);"
            >
            </div>
            <span class="font-allura text-[#ebccc4]" style="font-size:1.4rem;"
                >♡</span
            >
            <div
                style="height:1px; width:60px; background: linear-gradient(to left, transparent, #ebccc4);"
            >
            </div>
        </div>

        <!-- CARD TEXTO HISTORIA -->
        <div class="card-historia mb-6" id="card-historia">
            <p
                class="font-callingstone text-base text-[#63778d] tracking-widest leading-relaxed text-center mb-4"
            >
                Caminamos por los mismos pasillos del colegio durante años sin
                saber que el destino nos tenía guardados para el momento justo.
                Una mirada en el lugar menos esperado fue el inicio de todo.
            </p>
            <div class="flex justify-center my-3">
                <div class="w-8 h-px bg-[#ebccc4]/60"></div>
            </div>
            <p
                class="font-callingstone text-base text-[#63778d] tracking-widest leading-relaxed text-center mb-4"
            >
                Juntos descubrimos que la felicidad vive en los detalles, en las
                risas que no terminan y en esos abrazos que curan todo.
            </p>
            <div class="flex justify-center my-3">
                <div class="w-8 h-px bg-[#ebccc4]/60"></div>
            </div>
            <p
                class="font-callingstone text-base text-[#63778d] tracking-widest leading-relaxed text-center mb-4"
            >
                Entendimos que el amor es el viaje más valioso y hemos decidido
                recorrerlo siempre de la mano. Por eso, queremos celebrar
                nuestra historia con ustedes, que han sido parte de nuestro
                camino, y compartir la alegría de este nuevo comienzo.
            </p>
            <div class="flex justify-center my-3">
                <div class="w-8 h-px bg-[#ebccc4]/60"></div>
            </div>

            <!-- FLOR ARRIBA DERECHA — volteada horizontalmente -->
            <div class="relative w-full h-32 pointer-events-none mb-2">
                <img
                    src="/imagenes/florabajo.png"
                    alt=""
                    class="absolute bottom-10 -right-3 w-56 sm:w-44 object-contain z-20 scale-x-[-1]"
                    id="flor-galeria"
                />
            </div>
            <p
                class="font-callingstone text-base text-[#ebccc4] leading-relaxed text-center font-bold tracking-widest"
            >
                Nuestra boda es una celebración del amor, pero también de la
                amistad.
            </p>
        </div>

        <!-- FOTOS -->
        <div class="flex flex-col gap-4" id="fotos-galeria">
            <!-- FOTO 1 -->
            <div
                class="foto-card group cursor-pointer rounded-3xl overflow-hidden border border-[#ebccc4]/20"
                data-index="0"
            >
                <div class="relative aspect-[4/3]">
                    <img
                        src="/imagenes/Foto1.webp"
                        alt="Nuestra historia 1"
                        class="w-full h-full object-cover transform group-hover:scale-105 transition-transform duration-700 ease-out"
                    />
                    <div
                        class="absolute inset-0 bg-gradient-to-t from-black/40 via-transparent to-transparent opacity-60 group-hover:opacity-80 transition-opacity duration-500"
                    >
                    </div>
                    <div
                        class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 opacity-0 group-hover:opacity-100 scale-50 group-hover:scale-100 transition-all duration-500"
                    >
                        <div
                            class="w-16 h-16 rounded-full bg-white/20 backdrop-blur-xl flex items-center justify-center border border-white/40"
                        >
                            <svg
                                class="w-8 h-8 text-white"
                                fill="none"
                                stroke="currentColor"
                                viewBox="0 0 24 24"
                                stroke-linecap="round"
                            >
                                <circle
                                    cx="10.5"
                                    cy="10.5"
                                    r="6.5"
                                    stroke-width="2.5"></circle>
                                <path d="M15.5 15.5L21 21" stroke-width="2.5"
                                ></path>
                            </svg>
                        </div>
                    </div>
                </div>
            </div>

            <!-- FOTO 2 -->
            <div
                class="foto-card group cursor-pointer rounded-3xl overflow-hidden border border-[#ebccc4]/20"
                data-index="1"
            >
                <div class="relative aspect-[4/3]">
                    <img
                        src="/imagenes/foto2.webp"
                        alt="Nuestra historia 2"
                        class="w-full h-full object-cover transform group-hover:scale-105 transition-transform duration-700 ease-out"
                    />
                    <div
                        class="absolute inset-0 bg-gradient-to-t from-black/40 via-transparent to-transparent opacity-60 group-hover:opacity-80 transition-opacity duration-500"
                    >
                    </div>
                    <div
                        class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 opacity-0 group-hover:opacity-100 scale-50 group-hover:scale-100 transition-all duration-500"
                    >
                        <div
                            class="w-16 h-16 rounded-full bg-white/20 backdrop-blur-xl flex items-center justify-center border border-white/40"
                        >
                            <svg
                                class="w-8 h-8 text-white"
                                fill="none"
                                stroke="currentColor"
                                viewBox="0 0 24 24"
                                stroke-linecap="round"
                            >
                                <circle
                                    cx="10.5"
                                    cy="10.5"
                                    r="6.5"
                                    stroke-width="2.5"></circle>
                                <path d="M15.5 15.5L21 21" stroke-width="2.5"
                                ></path>
                            </svg>
                        </div>
                    </div>
                </div>
            </div>

            <!-- FOTO 3 -->
            <div
                class="foto-card group cursor-pointer rounded-3xl overflow-hidden border border-[#ebccc4]/20"
                data-index="2"
            >
                <div class="relative aspect-[4/3]">
                    <img
                        src="/imagenes/foto3.webp"
                        alt="Nuestra historia 3"
                        class="w-full h-full object-cover transform group-hover:scale-105 transition-transform duration-700 ease-out"
                    />
                    <div
                        class="absolute inset-0 bg-gradient-to-t from-black/40 via-transparent to-transparent opacity-60 group-hover:opacity-80 transition-opacity duration-500"
                    >
                    </div>
                    <div
                        class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 opacity-0 group-hover:opacity-100 scale-50 group-hover:scale-100 transition-all duration-500"
                    >
                        <div
                            class="w-16 h-16 rounded-full bg-white/20 backdrop-blur-xl flex items-center justify-center border border-white/40"
                        >
                            <svg
                                class="w-8 h-8 text-white"
                                fill="none"
                                stroke="currentColor"
                                viewBox="0 0 24 24"
                                stroke-linecap="round"
                            >
                                <circle
                                    cx="10.5"
                                    cy="10.5"
                                    r="6.5"
                                    stroke-width="2.5"></circle>
                                <path d="M15.5 15.5L21 21" stroke-width="2.5"
                                ></path>
                            </svg>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- MODAL -->
    <div
        id="modal-galeria"
        class="fixed inset-0 bg-black/95 backdrop-blur-3xl z-50 hidden items-center justify-center"
    >
        <button
            id="cerrar-modal"
            class="absolute top-6 right-6 w-12 h-12 rounded-full bg-white/10 backdrop-blur-xl flex items-center justify-center border border-white/20 hover:bg-white/20 transition-all duration-300 hover:rotate-90 z-50"
        >
            <svg
                class="w-5 h-5 text-white"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
            >
                <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M6 18L18 6M6 6l12 12"></path>
            </svg>
        </button>
        <div
            class="relative w-full h-full flex items-center justify-center px-12"
        >
            <button
                id="btn-anterior"
                class="absolute left-4 w-12 h-12 rounded-full bg-white/10 backdrop-blur-xl flex items-center justify-center border border-white/20 hover:bg-[#ebccc4]/20 transition-all duration-300 z-40"
            >
                <svg
                    class="w-5 h-5 text-white"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2.5"
                        d="M15 19l-7-7 7-7"></path>
                </svg>
            </button>
            <div
                class="relative max-w-sm w-full overflow-hidden"
                id="modal-contenido"
            >
                <div
                    id="carrusel-track"
                    class="flex transition-transform duration-700 ease-out"
                >
                </div>
                <div class="absolute bottom-4 left-1/2 -translate-x-1/2 z-30">
                    <div
                        class="bg-white/10 backdrop-blur-xl px-6 py-2 rounded-full border border-white/20"
                    >
                        <div class="flex items-center gap-3">
                            <span
                                id="numero-actual"
                                class="text-white font-callingstone text-xl font-bold"
                                >1</span
                            >
                            <div class="w-px h-5 bg-white/30"></div>
                            <span
                                id="numero-total"
                                class="text-white/60 font-callingstone text-lg"
                                >3</span
                            >
                        </div>
                    </div>
                </div>
            </div>
            <button
                id="btn-siguiente"
                class="absolute right-4 w-12 h-12 rounded-full bg-white/10 backdrop-blur-xl flex items-center justify-center border border-white/20 hover:bg-[#ebccc4]/20 transition-all duration-300 z-40"
            >
                <svg
                    class="w-5 h-5 text-white"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2.5"
                        d="M9 5l7 7-7 7"></path>
                </svg>
            </button>
        </div>
    </div>
</section>

<script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";
    gsap.registerPlugin(ScrollTrigger);

    if (typeof window !== "undefined") {
        document.addEventListener("DOMContentLoaded", () => {
            gsap.set("#galeria-onda", { opacity: 0, y: -20 });
            gsap.set("#flor-galeria", { opacity: 0, x: 30 });
            gsap.set("#card-historia", { opacity: 0, y: 30 });
            gsap.set(".foto-card", { opacity: 0, y: 40 });

            ScrollTrigger.create({
                trigger: "#seccion-galeria",
                start: "top 85%",
                onEnter: () => {
                    const tl = gsap.timeline();
                    tl.to("#galeria-onda", {
                        opacity: 1,
                        y: 0,
                        duration: 0.8,
                        ease: "power2.out",
                    })
                        .to(
                            "#flor-galeria",
                            {
                                opacity: 1,
                                x: 0,
                                duration: 0.8,
                                ease: "power2.out",
                            },
                            "-=0.4",
                        )
                        .to(
                            "#card-historia",
                            {
                                opacity: 1,
                                y: 0,
                                duration: 0.7,
                                ease: "power2.out",
                            },
                            "-=0.4",
                        )
                        .to(
                            ".foto-card",
                            {
                                opacity: 1,
                                y: 0,
                                duration: 0.6,
                                stagger: 0.15,
                                ease: "back.out(1.2)",
                            },
                            "-=0.3",
                        );
                },
                onLeaveBack: () => {
                    gsap.set("#galeria-onda", { opacity: 0, y: -20 });
                    gsap.set("#flor-galeria", { opacity: 0, x: 30 });
                    gsap.set("#card-historia", { opacity: 0, y: 30 });
                    gsap.set(".foto-card", { opacity: 0, y: 40 });
                },
            });

            // MODAL
            const fotos = [
                { src: "/imagenes/Foto1.webp" },
                { src: "/imagenes/foto2.webp" },
                { src: "/imagenes/foto3.webp" },
            ];

            let indiceActual = 0;
            const modal = document.getElementById("modal-galeria");
            const carruselTrack = document.getElementById("carrusel-track");
            const numeroActual = document.getElementById("numero-actual");
            const numeroTotal = document.getElementById("numero-total");
            const btnAnterior = document.getElementById("btn-anterior");
            const btnSiguiente = document.getElementById("btn-siguiente");
            const cerrarModal = document.getElementById("cerrar-modal");

            if (carruselTrack && numeroTotal) {
                numeroTotal.textContent = fotos.length.toString();
                fotos.forEach((foto) => {
                    const slide = document.createElement("div");
                    slide.className =
                        "min-w-full flex items-center justify-center px-2";
                    slide.innerHTML = `
            <div class="w-full rounded-3xl overflow-hidden border border-[#ebccc4]/20">
              <img src="${foto.src}" alt="Foto" class="w-full h-auto object-contain max-h-[80vh]" />
            </div>
          `;
                    carruselTrack.appendChild(slide);
                });
            }

            const actualizarCarrusel = (
                nuevo: number,
                animacion: boolean = true,
            ) => {
                if (!carruselTrack) return;
                indiceActual = (nuevo + fotos.length) % fotos.length;
                const desplazamiento = -indiceActual * 100;
                if (animacion) {
                    gsap.to(carruselTrack, {
                        x: `${desplazamiento}%`,
                        duration: 0.7,
                        ease: "power3.out",
                    });
                } else {
                    gsap.set(carruselTrack, { x: `${desplazamiento}%` });
                }
                if (numeroActual)
                    numeroActual.textContent = (indiceActual + 1).toString();
            };

            const abrirModal = (indice: number) => {
                if (!modal) return;
                modal.classList.remove("hidden");
                modal.classList.add("flex");
                document.body.style.overflow = "hidden";
                actualizarCarrusel(indice, false);
                gsap.fromTo(
                    modal,
                    { opacity: 0 },
                    { opacity: 1, duration: 0.4, ease: "power2.out" },
                );
                gsap.fromTo(
                    "#modal-contenido",
                    { scale: 0.85, opacity: 0 },
                    {
                        scale: 1,
                        opacity: 1,
                        duration: 0.6,
                        ease: "power3.out",
                        delay: 0.1,
                    },
                );
            };

            const cerrarModalFn = () => {
                if (!modal) return;
                gsap.to("#modal-contenido", {
                    scale: 0.85,
                    opacity: 0,
                    duration: 0.3,
                    ease: "power2.in",
                });
                gsap.to(modal, {
                    opacity: 0,
                    duration: 0.3,
                    ease: "power2.in",
                    delay: 0.1,
                    onComplete: () => {
                        modal.classList.add("hidden");
                        modal.classList.remove("flex");
                        document.body.style.overflow = "";
                    },
                });
            };

            document.querySelectorAll(".foto-card").forEach((card) => {
                card.addEventListener("click", () => {
                    const indice = parseInt(
                        card.getAttribute("data-index") || "0",
                    );
                    abrirModal(indice);
                });
            });

            btnAnterior?.addEventListener("click", (e) => {
                e.stopPropagation();
                actualizarCarrusel(indiceActual - 1);
            });
            btnSiguiente?.addEventListener("click", (e) => {
                e.stopPropagation();
                actualizarCarrusel(indiceActual + 1);
            });
            cerrarModal?.addEventListener("click", (e) => {
                e.stopPropagation();
                cerrarModalFn();
            });
            modal?.addEventListener("click", (e) => {
                if (e.target === modal) cerrarModalFn();
            });

            document.addEventListener("keydown", (e) => {
                if (modal && !modal.classList.contains("hidden")) {
                    if (e.key === "Escape") cerrarModalFn();
                    else if (e.key === "ArrowLeft")
                        actualizarCarrusel(indiceActual - 1);
                    else if (e.key === "ArrowRight")
                        actualizarCarrusel(indiceActual + 1);
                }
            });

            let touchStartX = 0;
            modal?.addEventListener(
                "touchstart",
                (e) => {
                    touchStartX = e.touches[0].clientX;
                },
                { passive: true },
            );
            modal?.addEventListener("touchend", (e) => {
                const diff = touchStartX - e.changedTouches[0].clientX;
                if (Math.abs(diff) > 60)
                    actualizarCarrusel(
                        diff > 0 ? indiceActual + 1 : indiceActual - 1,
                    );
            });
        });
    }
</script>

<style>
    .card-historia {
        background: rgba(255, 255, 255, 0.08);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border: 1px solid rgba(235, 204, 196, 0.25);
        border-radius: 24px;
        padding: 28px 24px;
        transition: all 0.3s ease;
    }
    .card-historia:hover {
        background: rgba(255, 255, 255, 0.12);
        box-shadow: 0 16px 40px rgba(235, 204, 196, 0.12);
    }
    .foto-card {
        transition: all 0.5s ease;
    }
    .foto-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 16px 40px rgba(99, 119, 141, 0.2);
        border-color: rgba(235, 204, 196, 0.4);
    }
</style>
