---
// DireccionSalon.astro
---

<section class="py-4 px-4 relative">
  <div class="max-w-xl mx-auto text-center relative">
    <!-- TÍTULO -->
    <div class="mb-2" id="titulo-direccion">
      <h2
        class="font-charm text-2xl md:text-3xl text-[#ecccc4] font-bold tracking-wide"
      >
        Recepción Social
      </h2>
    </div>

    <!-- ICONO CENTRAL -->
    <div class="relative mb-4" id="icono-salon">
      <div class="flex justify-center">
        <img
          src="/imagenes/recepcion.png"
          alt="Icono de dirección"
          class="w-24 h-24 md:w-28 md:h-28 lg:w-32 lg:h-32 object-contain icono-azul"
        />
      </div>
    </div>

    <!-- TÍTULO DIRECCIÓN -->
    <div class="mb-2" id="titulo-salon">
      <h2
        class="font-charm text-2xl md:text-3xl text-[#ecccc4] font-bold tracking-wide"
      >
        Dirección
      </h2>
    </div>

    <!-- INFORMACIÓN -->
    <div class="mb-2" id="info-direccion">
      <h3 class="font-charm text-xl md:text-2xl text-[#ecccc4] font-bold mb-2">
        Salón Mirador 360° Eventos y Convenciones
      </h3>
      <p
        class="font-charm text-lg md:text-xl text-[#62788d] leading-relaxed mb-3"
      >
        Irpavi 2 zona Aruntaya calle Ruiseñor
      </p>
      <p class="font-charm text-xl md:text-2xl text-[#ecccc4] font-bold">
        Hora: 16:00
      </p>
    </div>

    <!-- BOTÓN VER UBICACIÓN -->
    <div class="flex justify-center" id="boton-salon">
      <a
        href="https://maps.app.goo.gl/PEmrQJGmfospWs928"
        target="_blank"
        rel="noopener noreferrer"
        class="boton-ubicacion group"
      >
        <svg
          class="w-4 h-4 transition-transform duration-300 group-hover:-translate-y-0.5"
          viewBox="0 0 24 24"
          fill="currentColor"
        >
          <path
            d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"
          ></path>
        </svg>
        Ver ubicación
      </a>
    </div>
  </div>

  <script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";

    gsap.registerPlugin(ScrollTrigger);

    if (typeof window !== "undefined") {
      document.addEventListener("DOMContentLoaded", () => {
        gsap.set("#icono-salon", { opacity: 0, scale: 0.8 });
        gsap.set("#titulo-salon", { opacity: 0, scale: 0.9 });
        gsap.set("#titulo-direccion", { opacity: 0, scale: 0.9 });
        gsap.set("#info-direccion", { opacity: 0, scale: 0.9 });
        gsap.set("#boton-salon", { opacity: 0, scale: 0.9 });

        ScrollTrigger.create({
          trigger: "#icono-salon",
          start: "top 85%",
          end: "top 20%",
          onEnter: () => {
            const tl = gsap.timeline();
            tl.to(
              "#titulo-direccion, #icono-salon, #titulo-salon, #info-direccion, #boton-salon",
              { opacity: 1, duration: 1, ease: "power2.out" },
            )
              .to(
                "#icono-salon",
                { scale: 1, duration: 1, ease: "back.out(1.5)" },
                "<",
              )
              .to(
                "#titulo-direccion, #titulo-salon, #info-direccion, #boton-salon",
                { scale: 1, duration: 1, ease: "back.out(1.2)" },
                "<",
              );
          },
          onLeaveBack: () => {
            const tl = gsap.timeline();
            tl.to(
              "#titulo-direccion, #icono-salon, #titulo-salon, #info-direccion, #boton-salon",
              { opacity: 0, duration: 0.5, ease: "power2.in" },
            )
              .to(
                "#icono-salon",
                { scale: 0.8, duration: 0.5, ease: "power2.in" },
                "<",
              )
              .to(
                "#titulo-direccion, #titulo-salon, #info-direccion, #boton-salon",
                { scale: 0.9, duration: 0.5, ease: "power2.in" },
                "<",
              );
          },
        });

        console.log("🎉 Sección Salón inicializada");
      });
    }
  </script>

  <style>
    .icono-azul {
      filter: brightness(0) saturate(100%) invert(46%) sepia(40%) saturate(400%)
        hue-rotate(170deg) brightness(90%) contrast(90%);
      transition:
        filter 0.3s ease,
        transform 0.3s ease;
    }

    .boton-ubicacion {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 10px 28px;
      background: transparent;
      color: #62788d;
      border: 1.5px solid #62788d;
      border-radius: 50px;
      font-family: "Cormorant", serif;
      font-size: 14px;
      font-weight: 600;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      text-decoration: none;
      transition: all 0.3s ease;
    }

    .boton-ubicacion:hover {
      background: #62788d;
      color: white;
      box-shadow: 0 4px 16px rgba(98, 120, 141, 0.3);
      transform: translateY(-2px);
    }
  </style>
</section>
