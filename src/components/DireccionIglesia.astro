<!-- CONTENIDO -->
<section class="relative py-2 px-4 overflow-visible" id="seccion-direccion">
  <div class="max-w-xl mx-auto text-center" id="card-direccion">
    <!-- Línea decorativa superior -->
    <div class="flex items-center justify-center gap-3 mb-5">
      <div
        style="height:1px; width:60px; background: linear-gradient(to right, transparent, #ebccc4);"
      >
      </div>
      <span class="font-allura text-[#ebccc4]" style="font-size:1.4rem;">♡</span
      >
      <div
        style="height:1px; width:60px; background: linear-gradient(to left, transparent, #ebccc4);"
      >
      </div>
    </div>

    <!-- ICONO -->
    <div class="flex justify-center mb-4" id="icono-direccion">
      <img
        src="/imagenes/iglesia.png"
        alt="Icono iglesia"
        class="w-24 h-24 md:w-28 md:h-28 object-contain icono-color"
      />
    </div>

    <!-- INFO -->
    <div id="info-direccion">
      <h3
        class="font-callingstone text-[#63778d] tracking-widest text-base md:text-2xl font-bold mb-2"
      >
        Catedral Castrense
      </h3>
      <p
        class="font-callingstone text-[#ebccc4] tracking-widest mx-6 leading-relaxed mb-3 text-base"
      >
        Av. Rafael Pabón, calle 1 Zona Irpavi Al lado del Megacenter Zona Sur, <br
        />
        La Paz
      </p>
      <p
        class="font-callingstone text-[#63778d] tracking-widest font-bold text-base"
      >
        Hora: 14:00
      </p>
    </div>

    <!-- BOTÓN -->
    <div class="flex justify-center mt-5" id="boton-ubicacion">
      <a
        href="https://maps.app.goo.gl/gjhxkVo7CkjraHrD7"
        target="_blank"
        rel="noopener noreferrer"
        class="boton-ubicacion group font-callingstone"
      >
        <svg
          class="w-4 h-4 transition-transform duration-300 group-hover:-translate-y-0.5"
          viewBox="0 0 24 24"
          fill="currentColor"
        >
          <path
            d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"
          ></path>
        </svg>
        Ver ubicación
      </a>
    </div>
  </div>

  <!-- FLOR ABAJO IZQUIERDA — espejada -->
  <div class="relative w-full h-32 pointer-events-none">
    <img
      src="/imagenes/florabajo.png"
      alt=""
      id="flores-direccion"
      class="absolute bottom-17 -left-3 w-56 sm:w-44 object-contain z-20 scale-x-[-1]"
    />
  </div>
</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  if (typeof window !== "undefined") {
    document.addEventListener("DOMContentLoaded", () => {
      gsap.set("#direccion-onda", { opacity: 0, y: -20 });
      gsap.set("#card-direccion", { opacity: 0, y: 30 });
      gsap.set("#flores-direccion", { opacity: 0, x: -30 });

      ScrollTrigger.create({
        trigger: "#seccion-direccion",
        start: "top 85%",
        onEnter: () => {
          gsap.to("#direccion-onda", {
            opacity: 1,
            y: 0,
            duration: 0.8,
            ease: "power2.out",
          });
          gsap.to("#card-direccion", {
            opacity: 1,
            y: 0,
            duration: 1,
            ease: "power2.out",
            delay: 0.3,
          });
          gsap.to("#flores-direccion", {
            opacity: 1,
            x: 0,
            duration: 0.8,
            ease: "power2.out",
            delay: 0.4,
          });
        },
        onLeaveBack: () => {
          gsap.set("#direccion-onda", { opacity: 0, y: -20 });
          gsap.set("#card-direccion", { opacity: 0, y: 30 });
          gsap.set("#flores-direccion", { opacity: 0, x: -30 });
        },
      });
    });
  }
</script>

<style>
  .icono-color {
    filter: brightness(0) saturate(100%) invert(46%) sepia(40%) saturate(400%)
      hue-rotate(170deg) brightness(90%) contrast(90%);
  }

  .boton-ubicacion {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 28px;
    background: #ebccc4;
    color: white;
    border: none;
    border-radius: 50px;
    font-family: "Charm", cursive;
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform:;
    text-decoration: none;
    transition: all 0.3s ease;
  }

  .boton-ubicacion:hover {
    background: #4e6070;
    box-shadow: 0 4px 16px rgba(99, 119, 141, 0.4);
    transform: translateY(-2px);
  }
</style>
