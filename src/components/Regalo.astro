      <div
        style="height:1px; width:40px; background: linear-gradient(to right, transparent, #c9968d);"
      >
      </div>
      <span class="text-[#c9968d]" style="font-size:0.8rem;">♡</span>
      <div
        style="height:1px; width:40px; background: linear-gradient(to left, transparent, #c9968d);"
      >
      </div>
    </div>

    <!-- BNB -->
    <div class="flex flex-col items-center mb-6" id="bloque-bnb">
      <img
        src="/imagenes/bnb.png"
        alt="BNB"
        class="w-32 h-12 object-contain mb-5"
      />

      <!-- QR con marco elegante -->
      <div class="qr-frame mb-5" id="qr-img">
        <div class="qr-corner tl"></div>
        <div class="qr-corner tr"></div>
        <div class="qr-corner bl"></div>
        <div class="qr-corner br"></div>
        <img
          src="/imagenes/qr2.png"
          alt="QR BNB"
          class="w-52 h-52 object-contain rounded-xl"
        />
