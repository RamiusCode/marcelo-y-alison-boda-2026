<!-- CONTENIDO -->
<section class="py-6 px-4 relative overflow-hidden" id="seccion-regalo">
  <div class="max-w-sm mx-auto relative z-10">
    <!-- MENSAJE -->
    <div class="text-center mb-8" id="mensaje-qr">
      <div class="flex items-center justify-center gap-3 mb-4">
        <div
          style="height:1px; width:60px; background: linear-gradient(to right, transparent, #c9968d);"
        >
        </div>
        <span class="font-allura text-[#c9968d]" style="font-size:1.4rem;"
          >♡</span
        >
        <div
          style="height:1px; width:60px; background: linear-gradient(to left, transparent, #c9968d);"
        >
        </div>
      </div>
      <p
        class="font-callingstone text-[#c9968d] tracking-widest leading-relaxed text-base"
      >
        Su presencia es muy importante para nosotros, pero si desean hacernos un
        presente:
      </p>
    </div>

    <!-- MULTICENTER -->
    <div class="flex flex-col items-center mb-8" id="bloque-multicenter">
      <p class="font-callingstone text-base font-bold mb-4 tracking-widest">
        <span class="text-[#c9968d]">multi</span><span class="text-[#63778d]"
          >center</span
